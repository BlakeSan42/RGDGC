# RGDGC Backend API
RGDGC_API_URL=http://localhost:8000/api/v1
RGDGC_API_KEY=your-api-key-here

# Discord Bot
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_STANDINGS_CHANNEL_ID=
DISCORD_REMINDERS_CHANNEL_ID=

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=

# Claude AI
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# Scheduling (cron-style)
STANDINGS_POST_DAY=monday
STANDINGS_POST_HOUR=9
EVENT_REMINDER_HOURS=24,1

# Rate Limiting
AI_RATE_LIMIT_PER_USER=20
AI_RATE_LIMIT_WINDOW_SECONDS=3600

# Logging
LOG_LEVEL=INFO
