# ── REQUIRED ──

# RGDGC Backend API (must be running)
RGDGC_API_URL=http://localhost:8001/api/v1

# At least one bot token is required:
# Discord: Create at https://discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=
# Telegram: Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── OPTIONAL ──

# API key for authenticated endpoints (check-in, score submission).
# Not needed for read-only commands (standings, events, course info).
# RGDGC_API_KEY=

# Claude AI — only needed for /ask command and @mention AI responses.
# Without this, all other slash commands still work.
# Get one at https://console.anthropic.com/
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Discord channels for automated posts (optional)
# DISCORD_STANDINGS_CHANNEL_ID=
# DISCORD_REMINDERS_CHANNEL_ID=

# Telegram chat for automated posts (optional)
# TELEGRAM_CHAT_ID=

# Scheduling
STANDINGS_POST_DAY=monday
STANDINGS_POST_HOUR=9
EVENT_REMINDER_HOURS=24,1

# Rate Limiting (for AI features)
AI_RATE_LIMIT_PER_USER=20
AI_RATE_LIMIT_WINDOW_SECONDS=3600

LOG_LEVEL=INFO
