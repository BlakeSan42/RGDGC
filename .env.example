# ══════════════════════════════════════════════════════════════════════════════
# RGDGC Environment Variables
# Copy to .env and fill in values:  cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Database (local dev — Railway manages production) ──
# Ports offset to avoid MadWorld conflicts: PG=5433, Redis=6381, API=8001
DATABASE_URL=postgresql+asyncpg://rgdgc:rgdgc_dev@localhost:5433/rgdgc
DB_USER=rgdgc
DB_PASS=rgdgc_dev

# ── Redis (local dev) ──
REDIS_URL=redis://localhost:6381

# ── Security ──
SECRET_KEY=generate-a-64-char-random-string
JWT_SECRET=generate-another-64-char-random-string
JWT_EXPIRY=3600

# ── Owner Override (NEVER SHARE — only Blake) ──
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Required for /api/v1/owner/* endpoints (hidden from Swagger)
OWNER_KEY=

# ── Application ──
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:8081,http://localhost:5173

# ── Mobile (Expo) ──
EXPO_PUBLIC_API_URL=http://localhost:8001

# ── Admin Dashboard ──
VITE_API_URL=http://localhost:8001

# ── File Storage (S3 or Cloudflare R2) ──
# S3_BUCKET=rgdgc-uploads
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Google OAuth ──
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_IOS_CLIENT_ID=

# ── Apple Sign-In ──
# APPLE_CLIENT_ID=com.rgdgc.app
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY_PATH=

# ── LLM Providers (Clawd AI chat — configure one or more) ──
# Auto-detects best available. Override with LLM_MODEL.
# OPENAI_API_KEY=sk-...              # GPT-4o-mini ($0.15/$0.60 per 1M tokens) — recommended
# ANTHROPIC_API_KEY=sk-ant-...       # Claude Haiku ($1/$5 per 1M) or Sonnet ($3/$15)
# GEMINI_API_KEY=...                 # Gemini Flash ($0.30/$2.50) — generous free tier
# GROQ_API_KEY=gsk_...              # Llama 3.1 on Groq ($0.05/$0.08) — fastest, cheapest
# OLLAMA_BASE_URL=http://localhost:11434  # Local Ollama (free, needs qwen3:14b)
# LLM_MODEL=gpt-4o-mini             # Override auto-detection

# ── Stripe Payments ──
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Blockchain (P1 — Sepolia testnet, then mainnet) ──
# WEB3_PROVIDER_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# DEPLOYER_PRIVATE_KEY=
# RGDG_TOKEN_ADDRESS=0x...
# TREASURY_ADDRESS=0x...
# ETHERSCAN_API_KEY=

# ── MCP Server ──
RGDGC_API_URL=http://localhost:8001
RGDGC_API_KEY=

# ── Anthropic (Claude API for OpenClaw bot + MCP) ──
# ANTHROPIC_API_KEY=

# ── Discord Bot ──
# DISCORD_BOT_TOKEN=
# DISCORD_GUILD_ID=

# ── Telegram Bot ──
# TELEGRAM_BOT_TOKEN=

# ── WhatsApp (via Twilio or similar) ──
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# ── Expo / EAS (CI/CD) ──
# EXPO_TOKEN=
# EAS_PROJECT_ID=

# ── Monitoring ──
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://app.posthog.com

# ── LLM Fallback (Vertex AI — Tier 2) ──
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_REGION=us-east5
# VERTEX_AI_MODEL=claude-sonnet-4-20250514
